---
import type { TableOfContentsItem } from '../lib/blog';

interface Props {
  items: TableOfContentsItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <aside class="post-toc" aria-label="文章目录" data-toc>
    <div class="post-toc-inner">
      <p class="post-toc-title">文章目录</p>
      <ol class="post-toc-list">
        {items.map((item) => (
          <li class:list={[`depth-${item.depth}`]}>
            <a href={`#${item.slug}`} data-toc-link={item.slug}>{item.text}</a>
          </li>
        ))}
      </ol>
    </div>
  </aside>
)}
