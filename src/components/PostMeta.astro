---
import type { BlogPost } from '../lib/blog';
import { getTagPermalink } from '../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const formatDate = (value: Date) =>
  value.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });

const dateText = formatDate(post.data.pubDate);
const updatedDateText = post.data.updatedDate ? formatDate(post.data.updatedDate) : undefined;
---

<div class="post-meta">
  <time datetime={post.data.pubDate.toISOString()}>发布于 {dateText}</time>
  {updatedDateText && <span>最后更新于 {updatedDateText}</span>}
  <ul>
    {post.data.tags.map((tag: string) => (
      <li><a href={getTagPermalink(tag)}>{tag}</a></li>
    ))}
  </ul>
</div>
