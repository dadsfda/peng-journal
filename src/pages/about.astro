---
import { siteConfig } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = `关于 | ${siteConfig.title}`;
const pageDescription = '了解作者的关注方向、写作主题与联系方式。';
const focusAreas = ['设计与排版', '前端体验', '长期写作'];
const links = [
  { label: '邮箱', value: siteConfig.email, href: `mailto:${siteConfig.email}` },
  { label: '地点', value: siteConfig.location }
];
---

<BaseLayout title={pageTitle} description={pageDescription} path="/about/">
  <section class="about-page">
    <p class="eyebrow">About</p>
    <div class="about-intro">
      <h1>关于这个站点</h1>
      <p>
        {siteConfig.title} 是一个偏安静、偏长期的个人博客。我会在这里记录值得反复阅读的文章，
        也会整理一些和设计、前端体验、写作方法有关的思考。
      </p>
    </div>

    <div class="about-grid">
      <section class="about-card">
        <h2>我在关注什么</h2>
        <ul class="about-list">
          {focusAreas.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="about-card">
        <h2>写作说明</h2>
        <div class="about-copy">
          {siteConfig.about.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </section>
    </div>

    <section class="about-card about-contact">
      <h2>联系</h2>
      <ul class="about-links">
        {links.map((item) => (
          <li>
            <span>{item.label}</span>
            {item.href ? <a href={item.href}>{item.value}</a> : <strong>{item.value}</strong>}
          </li>
        ))}
      </ul>
    </section>
  </section>
</BaseLayout>
