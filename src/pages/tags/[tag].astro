---
import { getCollection } from 'astro:content';
import PostList from '../../components/PostList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts, getTagSlug } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = getPublishedPosts(await getCollection('blog'));
  const tags = getAllTags(posts);

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tagName: tag.name, tagSlug: tag.slug }
  }));
}

const { tagName, tagSlug } = Astro.props;
const posts = getPublishedPosts(await getCollection('blog')).filter((post) =>
  post.data.tags.some((item) => getTagSlug(item) === tagSlug)
);
const pageTitle = tagName + ' ' + '标签';
const pageDescription = '浏览 ' + tagName + ' ' + '标签下的文章。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PostList title={pageTitle} posts={posts} />
</BaseLayout>
