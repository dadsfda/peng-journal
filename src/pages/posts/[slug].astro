---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import PostTableOfContents from '../../components/PostTableOfContents.astro';
import {
  getAdjacentPosts,
  getPostPermalink,
  getPostSlug,
  getPublishedPosts,
  getSeriesPosts,
  getTableOfContents
} from '../../lib/blog';

export async function getStaticPaths() {
  const posts = getPublishedPosts(await getCollection('blog'));
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const allPosts = getPublishedPosts(await getCollection('blog'));
const { previousPost, nextPost } = getAdjacentPosts(allPosts, post);
const tableOfContents = getTableOfContents(headings);
const seriesPosts = post.data.series ? getSeriesPosts(allPosts, post.data.series) : [];
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <div class="post-layout" data-toc-script>
    <PostTableOfContents items={tableOfContents} />
    <article class="post-article">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <PostMeta post={post} />
        <p class="post-description">{post.data.description}</p>
      </header>
      <div class="post-body" data-post-content>
        <Content />
      </div>
      {seriesPosts.length > 0 && (
        <section class="post-series" aria-label="系列文章">
          <p class="eyebrow">Series</p>
          <h2>本系列文章</h2>
          <ol>
            {seriesPosts.map((seriesPost) => {
              const isCurrent = getPostSlug(seriesPost) === getPostSlug(post);
              return (
                <li>
                  {isCurrent ? (
                    <span aria-current="true">{seriesPost.data.title}</span>
                  ) : (
                    <a href={getPostPermalink(seriesPost)}>{seriesPost.data.title}</a>
                  )}
                </li>
              );
            })}
          </ol>
        </section>
      )}
      {(previousPost || nextPost) && (
        <nav class="post-pagination" aria-label={'文章分页'}>
          {previousPost && <a href={getPostPermalink(previousPost)}>{'上一篇：'}{previousPost.data.title}</a>}
          {nextPost && <a href={getPostPermalink(nextPost)}>{'下一篇：'}{nextPost.data.title}</a>}
        </nav>
      )}
    </article>
  </div>

  <script is:inline>
    {`
      (() => {
        const root = document.querySelector('[data-toc-script]');
        if (!root) return;

        const links = Array.from(root.querySelectorAll('[data-toc-link]'));
        const headings = Array.from(root.querySelectorAll('[data-post-content] h2, [data-post-content] h3'));
        if (!links.length || !headings.length) return;

        const linkMap = new Map(links.map((link) => [link.getAttribute('data-toc-link'), link]));

        const setActive = (slug) => {
          links.forEach((link) => {
            const isActive = link.getAttribute('data-toc-link') === slug;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'true');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        const observer = new IntersectionObserver(
          (entries) => {
            const visibleEntries = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

            const activeHeading = visibleEntries[0]?.target ?? headings[0];
            const activeSlug = activeHeading?.id;
            if (activeSlug && linkMap.has(activeSlug)) {
              setActive(activeSlug);
            }
          },
          {
            rootMargin: '-20% 0px -60% 0px',
            threshold: [0, 1]
          }
        );

        headings.forEach((heading) => observer.observe(heading));
        setActive(headings[0]?.id ?? '');
      })();
    `}
  </script>
</BaseLayout>
