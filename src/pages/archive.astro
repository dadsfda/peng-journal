---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getArchiveGroups, getPostPermalink, getPublishedPosts } from '../lib/blog';

const posts = getPublishedPosts(await getCollection('blog'));
const archiveGroups = getArchiveGroups(posts);
---

<BaseLayout title="文章归档" description="按月份回看博客文章。" path="/archive/">
  <section class="archive-page">
    <header class="archive-hero">
      <p class="eyebrow">Archive</p>
      <h1>文章归档</h1>
      <p>按时间回看已经发布的内容。</p>
    </header>

    {archiveGroups.length === 0 ? (
      <p class="archive-empty">暂时还没有已发布文章。</p>
    ) : (
      archiveGroups.map((yearGroup) => (
        <section class="archive-year">
          <h2>{yearGroup.year}</h2>
          {yearGroup.months.map((monthGroup) => (
            <div class="archive-month">
              <h3>{monthGroup.label}</h3>
              <ul class="archive-list">
                {monthGroup.posts.map((post) => (
                  <li>
                    <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
                    <a href={getPostPermalink(post)}>{post.data.title}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>
      ))
    )}
  </section>
</BaseLayout>
